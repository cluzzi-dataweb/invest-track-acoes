# Config central da camada de cotacoes no frontend
# mock | api | hybrid
VITE_QUOTES_PROVIDER=hybrid

# Habilita stream em tempo real via WebSocket
VITE_QUOTES_USE_WS=true

# Opcional: URL customizada do stream. Se vazio, usa VITE_API_URL/ws/quotes
VITE_QUOTES_WS_URL=

# Intervalo de atualizacao automatica (ms)
VITE_QUOTES_REFRESH_MS=30000

# Endpoint base da API (usado quando provider = api ou hybrid)
VITE_API_URL=http://localhost:3333

# Intervalo de push do backend websocket em milissegundos
WS_PUSH_INTERVAL_MS=12000

# Banco em nuvem real via Supabase (opcional, recomendado para usar de qualquer lugar)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_USERS_TABLE=invest_track_users
SUPABASE_CLOUD_TABLE=invest_track_cloud_data

# Autenticacao da aplicacao
AUTH_TOKEN_SECRET=troque-este-segredo-em-producao
AUTH_TOKEN_TTL_SECONDS=2592000
